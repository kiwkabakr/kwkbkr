# Production backend env. On the VPS this lives at /etc/czutkagg/backend.env (chmod 600).
# Do NOT commit the filled-in version.

PORT=3000
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=czutkagg

# 32+ char random string
JWT_SECRET=

# bcrypt hash of the admin password (use `htpasswd -bnBC 12 "" yourpass | tr -d ':\n'`)
ADMIN_PASSWORD_HASH=

# Long random string shared only with the telegram bot (NOT the bot token)
BOT_API_KEY=

# Telegram bot token — enables live deposit/payout notifications
TELEGRAM_BOT_TOKEN=

# Public site origin used for CORS
FRONTEND_URL=https://czutka.gg

# Crypto — required for deposit monitoring
MASTER_MNEMONIC=
ALCHEMY_API_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Cloudinary — optional image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UPLOAD_URL=
